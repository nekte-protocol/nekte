{
  "name": "@nekte/cli",
  "version": "0.2.0",
  "description": "NEKTE protocol CLI — discover, invoke, and inspect agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nekte": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",

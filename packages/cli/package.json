  },
  "dependencies": {
    "@nekte/core": "workspace:*",
    "@nekte/client": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}

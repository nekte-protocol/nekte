{
  "name": "nekte-protocol",
  "private": true,
  "description": "NEKTE — Token-efficient agent-to-agent coordination protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/nekte-protocol/nekte"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "eslint packages/*/src/**/*.ts",
    "format": "prettier --write packages/*/src/**/*.ts",
    "format:check": "prettier --check packages/*/src/**/*.ts",
    "clean": "pnpm -r clean",
    "demo": "tsx demo/two-agents/run.ts",
    "benchmark": "tsx benchmarks/src/cli.ts",
    "benchmark:real": "tsx benchmarks/real-mcp/index.ts",
    "benchmark:market": "tsx benchmarks/market-mcps/index.ts",
    "benchmark:old": "tsx benchmarks/token-comparison.ts",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "js-tiktoken": "^1.0.21",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
